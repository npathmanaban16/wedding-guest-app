{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "APP_VARIANT": "nn" },
      "ios": {
        "simulator": false,
        "image": "sdk-54"
      }
    },
    "saas-development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "APP_VARIANT": "saas" },
      "ios": {
        "simulator": false,
        "image": "sdk-54"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "autoIncrement": true,
      "env": { "APP_VARIANT": "nn" },
      "ios": {
        "simulator": false,
        "image": "sdk-54"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": { "APP_VARIANT": "nn" },
      "ios": {
        "image": "sdk-54"
      }
    },
    "saas-preview": {
      "distribution": "store",
      "channel": "saas-preview",
      "autoIncrement": true,
      "env": { "APP_VARIANT": "saas" },
      "ios": {
        "simulator": false,
        "image": "sdk-54"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "saas-production": {
      "channel": "saas-production",
      "autoIncrement": true,
      "env": { "APP_VARIANT": "saas" },
      "ios": {
        "image": "sdk-54"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "neha.pathmanaban@gmail.com",
        "ascAppId": "6762175655",
        "appleTeamId": "CS4LY75C25"
      }
    },
    "saas-production": {
      "ios": {
        "appleId": "neha.pathmanaban@gmail.com",
        "ascAppId": "6762950813",
        "appleTeamId": "CS4LY75C25"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
